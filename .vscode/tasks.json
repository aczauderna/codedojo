{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run CodeDojo Problem",
      "type": "shell",
      "command": "python3",
      "args": [
        "run.py",
        "${config:codeDojo.problemId}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
